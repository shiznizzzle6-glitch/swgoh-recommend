# Copy to .env and fill in. .env is gitignored.

# Your SWGOH ally code (digits only; dashes are stripped automatically).
SWGOH_ALLY_CODE=123456789

# Which data source to use: "swgoh_gg" (default, no setup) or "comlink".
SWGOH_DATA_SOURCE=swgoh_gg

# swgoh.gg API base (rarely needs changing).
SWGOH_GG_BASE_URL=https://api.swgoh.gg

# Only used when SWGOH_DATA_SOURCE=comlink. URL of your swgoh-comlink instance.
SWGOH_COMLINK_URL=http://localhost:3000

# Local cache for API responses (seconds). 0 disables caching.
SWGOH_CACHE_TTL=3600
SWGOH_CACHE_DIR=.cache
