# Copy to .env and fill in. .env is gitignored.

# Your SWGOH ally code (digits only; dashes are stripped automatically).
# Defaults to 474168985 if unset.
SWGOH_ALLY_CODE=474168985

# Which data source to use:
#   comlink  -> recommended; talks to the game servers, no Cloudflare gate.
#   swgoh_gg -> public API, but currently blocked by Cloudflare for code clients.
SWGOH_DATA_SOURCE=comlink

# swgoh.gg API base (main domain; note: the old api.swgoh.gg host is dead).
SWGOH_GG_BASE_URL=https://swgoh.gg/api

# Used when SWGOH_DATA_SOURCE=comlink. Matches docker-compose.comlink.yml.
SWGOH_COMLINK_URL=http://localhost:3200

# Local cache for API responses (seconds). 0 disables caching.
SWGOH_CACHE_TTL=3600
SWGOH_CACHE_DIR=.cache
